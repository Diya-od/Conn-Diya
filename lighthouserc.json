{
  "ci": {
    "collect": {
      "numberOfRuns": 3,
      "url": ["http://127.0.0.1:8080/"]
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.75 }],
        "categories:accessibility": ["warn", { "minScore": 0.9 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
